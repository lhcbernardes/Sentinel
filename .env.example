# ───────────────────────────────────────────────────
# sentinel-rs — variáveis de ambiente obrigatórias
# Copie este arquivo para .env e preencha os valores
# ───────────────────────────────────────────────────

# Segredo para assinatura de tokens JWT — OBRIGATÓRIO em produção.
# Mínimo 32 caracteres. Gere com: openssl rand -hex 32
SENTINEL_JWT_SECRET=mude_para_um_segredo_seguro_de_pelo_menos_32_chars

# Senha do usuário admin padrão — MUDE ANTES DE SUBIR EM PRODUÇÃO
# Requisitos: min 8 chars, 1 maiúscula, 1 número, 1 caractere especial
SENTINEL_ADMIN_PASSWORD=Sentinel@2024

# Senha do Grafana — OBRIGATÓRIA para o docker-compose
GF_ADMIN_PASSWORD=mude_esta_senha_do_grafana
GF_ADMIN_USER=admin

# Origem permitida para CORS (default: localhost:8080)
# ALLOWED_ORIGIN=http://192.168.1.100:8080

# Configurações da aplicação
INTERFACE=eth0
LISTEN_ADDR=0.0.0.0:8080
DB_PATH=data/sentinel.db
OUI_PATH=data/oui.txt
SNIFFER_ENABLED=true
DNS_ENABLED=false
DNS_PORT=53
FIREWALL_ENABLED=true
RUST_LOG=info
